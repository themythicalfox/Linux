#!/bin/sh
# live-build configuration for ArchonSync.
# All distro identity lives here and in config/hooks/normal/0900-branding.hook.chroot.

set -e

DISTRO_NAME="${DISTRO_NAME:-ArchonSync}"
DISTRO_VERSION="${DISTRO_VERSION:-1.0}"
DEBIAN_RELEASE="${DEBIAN_RELEASE:-trixie}"

lb config noauto \
    --mode debian \
    --distribution "${DEBIAN_RELEASE}" \
    --architecture amd64 \
    --linux-packages "linux-image linux-headers" \
    --archive-areas "main contrib non-free non-free-firmware" \
    --debian-installer none \
    --binary-images iso-hybrid \
    --bootappend-live "boot=live components quiet splash username=archon hostname=archonsync" \
    --iso-application "${DISTRO_NAME}" \
    --iso-volume "${DISTRO_NAME}-${DISTRO_VERSION}" \
    --iso-publisher "themythicalfox" \
    --image-name "${DISTRO_NAME}-${DISTRO_VERSION}" \
    --memtest none \
    --firmware-chroot false \
    --firmware-binary false \
    --apt-recommends true \
    "${@}"
