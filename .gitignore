# live-build working directories and outputs
/.build/
/cache/
/chroot/
/chroot.tmp/
/chroot.files
/chroot.packages.*
/binary/
/binary.modified_timestamps
/local/
*.iso
*.iso.zsync
*.contents
*.files
*.packages
*.buildlog
build.log
boot-test.log
SHA256SUMS

# live-build regenerates these from auto/config
/.lock
/config/binary
/config/bootstrap
/config/chroot
/config/common
/config/source
/config/hooks/live
/config/hooks/normal/[1-9][0-9][0-9][0-9]-*
/config/package-lists/live.list.chroot
chroot.installed_tmp_pkgs
/config/packages.chroot/*.deb
/.preview/

# ArchonSync desktop binaries/assets staged into the image by
# scripts/build-desktop.sh (regenerated by `make desktop`; never committed).
/config/includes.chroot/usr/local/bin/archon-comp
/config/includes.chroot/usr/local/bin/archon-shell
/config/includes.chroot/usr/local/bin/archonctl
/config/includes.chroot/usr/local/bin/archonsync-session
/config/includes.chroot/usr/share/wayland-sessions/archonsync.desktop
/config/includes.chroot/usr/share/archonsync/desktop/
