#!/bin/sh
# ArchonSync first-boot setup wizard (OOBE).
#
# Runs once per user on first login and walks them through the choices that
# matter on ArchonSync: desktop layout, apps & accounts, Windows dual-boot,
# privacy, and network. Every step is optional and best-effort — cancelling or
# an error never blocks finishing. Stamp-guarded so it only runs once.
#
# Built on kdialog (always installed) so it ships with no compile step. A
# fancier branded window can replace this later without changing the flow.

set -u

STAMP="$HOME/.config/archonsync-setup.done"
[ -f "$STAMP" ] && exit 0

# If kdialog isn't available for some reason, fall back to the simple welcome.
if ! command -v kdialog >/dev/null 2>&1; then
    [ -x /usr/local/bin/archonsync-welcome ] && /usr/local/bin/archonsync-welcome
    exit 0
fi

TITLE="ArchonSync Setup"
TOTAL=6
launch() { setsid "$@" >/dev/null 2>&1 & }
step()   { kdialog --title "$TITLE — step $1 of $TOTAL" "$@"; }

# ---------------------------------------------------------------------------
# 1. Welcome
# ---------------------------------------------------------------------------
step 1 --msgbox "Welcome to ArchonSync — your PC, faster, cleaner and locked down.

Let's make it yours with a few quick choices. You can change any of these later
in the Control Center. Click OK to begin." || { touch "$STAMP"; exit 0; }

# ---------------------------------------------------------------------------
# 2. Desktop layout
# ---------------------------------------------------------------------------
LAYOUT=$(step 2 --radiolist "How do you want your desktop to look?

(You can switch anytime in the Control Center.)" \
    wheel   "Side dial — the Wheel (ArchonSync signature)" on \
    taskbar "Bottom taskbar — familiar, Windows-style" off \
    topbar  "Top bar — clean, macOS-style" off 2>/dev/null) || LAYOUT=""
[ -n "$LAYOUT" ] && archonsync-layout "$LAYOUT" >/dev/null 2>&1 || true

# ---------------------------------------------------------------------------
# 3. Apps & accounts
# ---------------------------------------------------------------------------
step 3 --msgbox "Your apps are being set up in the background:

  • Steam — your whole game library (Proton for Windows games)
  • Discord, Minecraft (Prism Launcher), and game launchers
  • Firefox with ad/tracker blocking built in

Sign into each with your normal account and everything syncs with Windows —
say something on Discord here, it's there on Windows too." || true

if command -v steam >/dev/null 2>&1; then
    if step 3 --yesno "Open Steam now to sign in?"; then
        launch steam
    fi
fi

# ---------------------------------------------------------------------------
# 4. Windows dual-boot (only if a Windows drive is present)
# ---------------------------------------------------------------------------
has_windows=0
if [ -d /windows/Windows ] || lsblk -no FSTYPE 2>/dev/null | grep -qi ntfs; then
    has_windows=1
fi
if [ "$has_windows" -eq 1 ]; then
    step 4 --msgbox "Windows was found on this PC — you're set up for dual-boot.

  • 'Windows Mode' (Control Center or the Wheel) reboots straight into Windows;
    the next restart brings you back to ArchonSync.
  • Your Windows files are available here under your home folder, so it's the
    same files on both systems.
  • League of Legends / Valorant need Windows (their anti-cheat blocks Linux) —
    use the 'Play on Windows' shortcut for those." || true
else
    step 4 --msgbox "No second OS detected — ArchonSync has the whole drive.

If you add Windows later for games like League of Legends (which need Windows),
ArchonSync will pick it up for one-click dual-boot." || true
fi

# ---------------------------------------------------------------------------
# 5. Privacy & security (already on — just confirm/allow opt-out)
# ---------------------------------------------------------------------------
if step 5 --yesno "ArchonSync is already locked down and ad-free:

  • System-wide ad / tracker / malware blocking
  • Firewall, antivirus, encrypted DNS, automatic security updates

Keep ad & tracker blocking ON? (Recommended)"; then
    archonsync-adblock on >/dev/null 2>&1 || true
else
    archonsync-adblock off >/dev/null 2>&1 || true
fi

# ---------------------------------------------------------------------------
# 6. Network tuning (optional)
# ---------------------------------------------------------------------------
if command -v speedtest-cli >/dev/null 2>&1 || command -v speedtest >/dev/null 2>&1; then
    if step 6 --yesno "Your connection is already tuned for low lag and high speed.

Pin it to your exact line speed for the lowest possible ping under load? (runs a
quick ~30s speed test)"; then
        ( archonsync-netspeed auto >/dev/null 2>&1 || true ) &
    fi
else
    step 6 --msgbox "Your connection is tuned for low lag and high speed out of the box
(BBR + CAKE + traffic prioritisation for games, Discord and streaming).

To pin it to your exact line speed later, open a terminal and run:
  archonsync-netspeed <download> <upload>" || true
fi

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
kdialog --title "$TITLE — all set!" --msgbox "You're ready to go!

  • The Control Center has Settings, Task Manager, Hardware and every toggle.
  • Game Mode = max performance + low-latency network, one click.
  • Switch desktop layouts anytime in the Control Center.

Welcome to ArchonSync." || true

mkdir -p "$(dirname "$STAMP")"
touch "$STAMP"
