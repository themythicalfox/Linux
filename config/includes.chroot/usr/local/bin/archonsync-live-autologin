#!/bin/sh
# Make the live ISO boot straight to the desktop by enabling SDDM autologin for
# the live user, and make the desktop actually render inside virtual machines.
#
# Gated to the live session by the systemd unit
# (ConditionKernelCommandLine=boot=live), so an installed system never runs this
# and keeps a normal login screen on its real GPU.
set -e

mkdir -p /etc/sddm.conf.d

# Which session to autologin into. KDE Plasma 6 / KWin black-screens in some VMs
# (it needs GPU compositing the virtual GPU can't provide). The lightweight XFCE
# session renders fine with plain software graphics, so the live ISO autologins
# into XFCE inside a VM to guarantee a usable desktop; on real hardware it boots
# the full ArchonSync Plasma desktop. KDE is selectable from the login screen in
# either case.
SESSION="plasmax11.desktop"
if systemd-detect-virt --quiet 2>/dev/null; then
    SESSION="xfce.desktop"
fi

cat > /etc/sddm.conf.d/zz-archonsync-live-autologin.conf <<CONF
[Autologin]
User=archon
Session=$SESSION
Relogin=false
CONF

# In a virtual machine, the virtual GPU's OpenGL is often missing or too limited
# to composite, which shows up as a black screen or freeze right after login.
# Force software rendering so the desktop always draws (slower, but this is just
# a "try it" session):
#   LIBGL_ALWAYS_SOFTWARE  -> compositing on llvmpipe (software OpenGL)
#   QT_QUICK_BACKEND       -> Qt/QML render via the software scene graph
# pam_env reads /etc/environment for the SDDM-started session.
if systemd-detect-virt --quiet 2>/dev/null; then
    {
        echo "LIBGL_ALWAYS_SOFTWARE=1"
        echo "QT_QUICK_BACKEND=software"
        echo "WLR_RENDERER_ALLOW_SOFTWARE=1"
    } >> /etc/environment
fi
